<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DominoDO.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DominoDO"
    Title="DominoDO"
    xmlns:pages="clr-namespace:DominoDO.Pages">

    <Shell.TitleView>
        <Grid>
            <Image Source="dominodologo.png" HeightRequest="150" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>
    </Shell.TitleView> 
    
       <ShellContent
        ContentTemplate="{DataTemplate pages:HomePage}"
        Route="home"                       
        Shell.BackgroundColor="White"/>

</Shell>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DominoDO.Pages.HomePage"
             Title="HomePage"
             BackgroundColor="White">
    <StackLayout>
        <Grid ColumnDefinitions="*, *" 
      RowDefinitions="Auto, Auto" 
      Padding="10">

            <Button Grid.Row="0" Grid.Column="0" Text="Team 1" BackgroundColor="#30B7FF" Margin="5" />
            <Button Grid.Row="0" Grid.Column="1" Text="Team 2" BackgroundColor="#FF9933" Margin="5" />

            <Entry Grid.Row="1" Grid.Column="0" Placeholder="Entry 1" Margin="5" Keyboard="Numeric"/>
            <Entry Grid.Row="1" Grid.Column="1" Placeholder="Entry 2" Margin="5" Keyboard="Numeric"/>

        </Grid>
    </StackLayout>
</ContentPage>